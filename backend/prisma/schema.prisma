generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password_hash String
  phone         String?
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  vehicles      Vehicle[]
  favorites     Favorite[]
  refresh_tokens RefreshToken[]

  @@map("users")
}

model Vehicle {
  id          String          @id @default(uuid())
  user_id     String
  brand       String
  model       String
  version     String?
  year_fab    Int
  year_model  Int
  mileage_km  Int
  price       Decimal         @db.Decimal(12, 2)
  condition   VehicleCondition
  description String?
  status      VehicleStatus   @default(active)
  lat         Float
  lng         Float
  neighborhood String?
  city        String
  state       String          @db.VarChar(2)
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt
  user        User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  features    VehicleFeatures?
  images      VehicleImage[]
  favorites   Favorite[]

  @@map("vehicles")
}

model VehicleFeatures {
  vehicle_id     String           @id
  transmission   Transmission
  fuel           Fuel
  color          String
  doors          Int
  ac             Boolean          @default(false)
  power_steering Boolean          @default(false)
  abs            Boolean          @default(false)
  airbags        Int              @default(0)
  vehicle        Vehicle          @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  @@map("vehicle_features")
}

model VehicleImage {
  id         String  @id @default(uuid())
  vehicle_id String
  url        String
  order      Int     @default(0)
  is_cover   Boolean @default(false)
  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  @@map("vehicle_images")
}

model Favorite {
  user_id    String
  vehicle_id String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  vehicle    Vehicle  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)

  @@id([user_id, vehicle_id])
  @@map("favorites")
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum VehicleCondition {
  new
  used
  certified
}

enum VehicleStatus {
  active
  paused
  sold
}

enum Transmission {
  manual
  automatic
  cvt
}

enum Fuel {
  flex
  gasoline
  diesel
  electric
  hybrid
}
